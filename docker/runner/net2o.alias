DEVICES=$(find /dev/dri -type c | sed -e 's/^.*$/--device=\0:\0/g' | tr '\n' ' ')
USERMAP="$(id -u):$(\ls -ng /dev/dri/render* | head -1 | sed -e 's/  */ /g' | cut -f3 -d' ')"

alias net2odk="docker run -ti --rm -v ~/net2o.dk:/net2o --user $USERMAP forthy42/net2o"
alias net2o-guidk="docker run -ti --rm -v ~/net2o.dk:/net2o --user $USERMAP  -e XDG_RUNTIME_DIR=/tmp/xdg-runtime-dir -e USER=$USER -e DISPLAY=$DISPLAY -e XDG_SESSION_TYPE=\$XDG_SESSION_TYPE -e WAYLAND_DISPLAY=\$WAYLAND_DISPLAY -v /tmp/.X11-unix/:/tmp/.X11-unix/ -v /dev/dri:/dev/dri -v /usr/share/fonts:/usr/share/fonts -v $XAUTHORITY:/home/gforth/.Xauthority -v ~/.fonts:/home/gforth/.fonts -v \${XDG_RUNTIME_DIR}:/tmp/xdg-runtime-dir -v ${XDG_RUNTIME_DIR}/pulse:/run/user/1000/pulse forthy42/net2o-gui"
alias net2o-gui-fontsdk="docker run -ti --rm -v ~/net2o.dk:/net2o --user $(id -u):$(id -g) -e XDG_RUNTIME_DIR=/tmp/xdg-runtime-dir -e USER=$USER -e DISPLAY=$DISPLAY -e XDG_SESSION_TYPE=\$XDG_SESSION_TYPE -e WAYLAND_DISPLAY=\$WAYLAND_DISPLAY -v /tmp/.X11-unix/:/tmp/.X11-unix/ -v /dev/dri:/dev/dri -v $XAUTHORITY:/home/gforth/.Xauthority -v ~/.fonts:/home/gforth/.fonts -v \${XDG_RUNTIME_DIR}:/tmp/xdg-runtime-dir -v ${XDG_RUNTIME_DIR}/pulse:/run/user/1000/pulse forthy42/net2o-gui-fonts"
unset DEVICES
unset USERMAP
